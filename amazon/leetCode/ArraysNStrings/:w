def strStr(haystack, needle):
  n = len(needle)
  m = len(haystack)
  if n > m:
    return -1


  for i in range(m):
    if needle[0] == haystack[i]:
      idx = i

      for j in range(1, n):
        if needle[j] != haystack[i + j]:
          break

        if j == n - 1:
          return i

        idx += 1
      i = idx
    print(i)

  return -1

haystack = "kkkkksasbutsad"

needle = "sad"
print(strStr(haystack, needle))


